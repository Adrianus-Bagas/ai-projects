# Menggunakan image Python sebagai fondasi container.
FROM python:3.12-slim

# Menentukan folder kerja utama di dalam container.
WORKDIR /app

# Menyalin executable uv dari image resmi uv.
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# Menyalin konfigurasi project API terlebih dahulu.
COPY apps/api/pyproject.toml apps/api/uv.lock ./apps/api/

# Menyalin konfigurasi package database lokal.
COPY packages/database/pyproject.toml ./packages/database/

# Menyalin konfigurasi package auth lokal.
COPY packages/auth/pyproject.toml ./packages/auth/

# Menyalin README karena pyproject package database mereferensikannya.
COPY packages/database/README.md ./packages/database/

# Menyalin source code Python package database.
COPY packages/database/database ./packages/database/database

# Menyalin README karena pyproject package auth mereferensikannya.
COPY packages/auth/README.md ./packages/auth/

# Menyalin source code Python package auth.
COPY packages/auth/auth ./packages/auth/auth

# Menyalin source code Python package auth test.
COPY packages/auth/tests ./packages/auth/tests

# Berpindah ke folder project API.
WORKDIR /app/apps/api

# Menginstal dependency berdasarkan lockfile tanpa memperbaruinya.
RUN uv sync --frozen

# Menyalin seluruh source code API setelah dependency selesai dipasang.
COPY apps/api ./ 

# Menjalankan FastAPI development server.
CMD ["uv", "run", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]