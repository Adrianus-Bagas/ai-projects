{
  "name": "ai-workspace",
  "private": true,
  "packageManager": "pnpm@10.34.5",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "docker:up": "docker compose --env-file .env -f infrastructure/compose/docker-compose.dev.yml up",
    "docker:up:d": "docker compose --env-file .env -f infrastructure/compose/docker-compose.dev.yml up -d",
    "docker:down": "docker compose --env-file .env -f infrastructure/compose/docker-compose.dev.yml down",
    "docker:stop": "docker compose --env-file .env -f infrastructure/compose/docker-compose.dev.yml stop",
    "docker:start": "docker compose --env-file .env -f infrastructure/compose/docker-compose.dev.yml start",
    "docker:restart": "pnpm docker:down && pnpm docker:up",
    "docker:build": "docker compose --env-file .env -f infrastructure/compose/docker-compose.dev.yml build",
    "docker:rebuild": "docker compose --env-file .env -f infrastructure/compose/docker-compose.dev.yml up --build",
    "docker:rebuild:d": "docker compose --env-file .env -f infrastructure/compose/docker-compose.dev.yml up --build -d",
    "docker:logs": "docker compose --env-file .env -f infrastructure/compose/docker-compose.dev.yml logs -f",
    "docker:logs:api": "docker compose --env-file .env -f infrastructure/compose/docker-compose.dev.yml logs -f api",
    "docker:logs:web": "docker compose --env-file .env -f infrastructure/compose/docker-compose.dev.yml logs -f web",
    "docker:logs:db": "docker compose --env-file .env -f infrastructure/compose/docker-compose.dev.yml logs -f postgres",
    "docker:ps": "docker compose --env-file .env -f infrastructure/compose/docker-compose.dev.yml ps",
    "docker:config": "docker compose --env-file .env -f infrastructure/compose/docker-compose.dev.yml config",
    "shell:api": "docker compose --env-file .env -f infrastructure/compose/docker-compose.dev.yml exec api sh",
    "shell:web": "docker compose --env-file .env -f infrastructure/compose/docker-compose.dev.yml exec web sh",
    "shell:db": "docker compose --env-file .env -f infrastructure/compose/docker-compose.dev.yml exec postgres sh",
    "db:psql": "docker compose --env-file .env -f infrastructure/compose/docker-compose.dev.yml exec postgres psql -U postgres",
    "migration:upgrade": "docker compose --env-file .env -f infrastructure/compose/docker-compose.dev.yml exec api alembic upgrade head",
    "migration:downgrade": "docker compose --env-file .env -f infrastructure/compose/docker-compose.dev.yml exec api alembic downgrade -1",
    "migration:current": "docker compose --env-file .env -f infrastructure/compose/docker-compose.dev.yml exec api alembic current",
    "migration:history": "docker compose --env-file .env -f infrastructure/compose/docker-compose.dev.yml exec api alembic history"
  },
  "devDependencies": {
    "turbo": "^2.10.4"
  }
}
